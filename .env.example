# Database
DATABASE_URL="file:./dev.db"

# Auth (generate a random 64-char hex string)
JWT_SECRET="change-this-to-a-random-secret"

# Stripe — get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create products at https://dashboard.stripe.com/products
STRIPE_SUPPORTER_PRICE_ID="price_supporter_monthly"
STRIPE_PRO_PRICE_ID="price_pro_monthly"

# AI Agents (Next.js runtime) — at least ONE provider key is required for the
# on-site agents at /api/agents/[type]. Auto-detected in this order:
# anthropic -> openai -> groq. Groq has a generous FREE tier (console.groq.com),
# so it's the easiest way to get the agents working without paying.
GROQ_API_KEY="gsk_your_api_key_here"   # free tier — recommended to start
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
# Optional overrides:
LLM_PROVIDER="groq"                    # "anthropic" | "openai" | "groq"
ANTHROPIC_MODEL="claude-haiku-4-5"
OPENAI_MODEL="gpt-4o-mini"
GROQ_MODEL="llama-3.3-70b-versatile"
